# Brewfather API credentials (read-only).
# Required so the server can fetch your live inventory and saved recipes.
#
# Generate a key in Brewfather: Settings -> API (requires Brewfather Premium).
# One key per account. Auth is HTTP Basic over base64("BF_USER_ID:BF_API_KEY")
# and is only ever used server-side; it never reaches the browser.
#
# Copy this file to ".env" and fill in your values. Never commit your real .env.

# Your Brewfather user id.
BF_USER_ID=

# Your Brewfather API key (secret).
BF_API_KEY=
