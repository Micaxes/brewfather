# Brewfather API credentials (read-only).
# Required so the server can fetch your live inventory and saved recipes.
#
# Generate a key in Brewfather: Settings -> API (requires Brewfather Premium).
# One key per account. Auth is HTTP Basic over base64("BF_USER_ID:BF_API_KEY")
# and is only ever used server-side; it never reaches the browser.
#
# Copy this file to ".env" and fill in your values. Never commit your real .env.

# Your Brewfather user id.
BF_USER_ID=

# Your Brewfather API key (secret).
BF_API_KEY=

# ---------------------------------------------------------------------------
# Supabase (v1: auth + hosted). Put real values in .env.local (gitignored) and
# mirror them in Vercel → Project → Settings → Environment Variables.
# Find them in Supabase → Project Settings → API. The NEXT_PUBLIC_* values are
# safe to expose to the browser; SUPABASE_SECRET_KEY must stay server-only.
# ---------------------------------------------------------------------------

# Supabase project URL, e.g. https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable (client) key — sb_publishable_...
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret (server-only) key — sb_secret_...  Bypasses RLS; never expose.
SUPABASE_SECRET_KEY=

# JWKS URL for verifying Supabase-signed JWTs, e.g. <url>/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=
